# Mailchimp Marketing API
# Create key: Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=your_key-us21

# Audience ID: Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=your_list_id

# subscribed = immediate | pending = double opt-in confirmation email
MAILCHIMP_STATUS=subscribed
